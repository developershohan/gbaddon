{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "plugin-markup-with-composer/heading-block",
	"version": "1.0.0",
	"title": "Heading Block",
	"category": "text",
	"description": "Display your site's heading.",
	"icon": "heading",
	"keywords": [
		"heading",
		"title",
		"block"
	],
	"attributes": {
		"content": {
			"type": "string",
			"default": "Heading Text"
		},
		"level": {
			"type": "number",
			"default": 2
		},
		"textAlign": {
			"type": "string"
		}
	},
	"supports": {
		"color": {
			"background": false,
			"text": true
		},
		"html": false,
		"typography": {
			"fontSize": true
		},
		"align": ["left", "center", "right"],
		"background": {
			"color": true,
			"gradient": false,
			"image": false
		}
	},
	"textdomain": "plugin-markup-with-composer",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
